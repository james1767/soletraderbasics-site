---
const { title, description } = Astro.props;
const path = Astro.url.pathname;
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />

    <meta
      name="google-site-verification"
      content="Jkx2Lr4NsLiSiEUQZ8g6f0sxLw6payST_wy8FXOrR7s"
    />

    <meta
      name="description"
      content={description || "Simple, practical guides for UK sole traders."}
    />
    <meta
      property="og:description"
      content={description || "Simple, practical guides for UK sole traders."}
    />

    <title>{title}</title>
    <meta property="og:title" content={title} />

    <style>
      :root {
        --bg: #f5f7fb;
        --surface: #ffffff;
        --text: #0f172a;
        --muted: #475569;
        --border: #e2e8f0;
        --link: #2563eb;
        --link-hover: #1d4ed8;
        --shadow: 0 10px 30px rgba(15, 23, 42, 0.08);
      }
      .section {
        margin-top: 2rem;
        padding: 1.5rem;
        background: #ffffff;
        border: 1px solid var(--border);
        border-radius: 16px;
      }

      .section h2 {
        border-top: none;
        margin-top: 0;
      }

      .section h3 {
        margin-top: 1.2rem;
      }
      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        font-family:
          Inter,
          system-ui,
          -apple-system,
          BlinkMacSystemFont,
          "Segoe UI",
          sans-serif;
        line-height: 1.7;
        background: radial-gradient(circle at top, #ffffff 0%, var(--bg) 55%);
        color: var(--text);
      }

      main {
        max-width: 820px;
        margin: 48px auto;
        padding: 32px 28px 56px;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 20px;
        box-shadow: var(--shadow);
      }

      h1,
      h2,
      h3 {
        line-height: 1.2;
        letter-spacing: -0.02em;
        margin-bottom: 0.75rem;
      }

      h1 {
        margin-top: 0;
        font-size: clamp(2rem, 3vw, 2.7rem);
      }

      h2 {
        margin-top: 2.5rem;
        font-size: clamp(1.35rem, 2vw, 1.7rem);
        padding-top: 0.25rem;
        border-top: 1px solid var(--border);
      }

      h3 {
        margin-top: 1.75rem;
        font-size: 1.15rem;
        color: var(--text);
      }

      p {
        margin: 1rem 0;
        color: var(--text);
      }

      strong {
        color: var(--text);
      }

      em {
        color: var(--muted);
      }

      a:link,
      a:visited,
      main a:link,
      main a:visited,
      .section a:link,
      .section a:visited {
        color: #2563eb !important;
        text-decoration: none;
        font-weight: 500;
      }

      a:hover,
      a:focus,
      main a:hover,
      main a:focus,
      .section a:hover,
      .section a:focus {
        color: #1d4ed8 !important;
        text-decoration: underline;
        text-underline-offset: 2px;
      }

      ul,
      ol {
        padding-left: 1.4rem;
        margin: 1rem 0 1.25rem;
      }

      li {
        margin: 0.45rem 0;
      }

      hr {
        border: 0;
        border-top: 1px solid var(--border);
        margin: 2rem 0;
      }

      blockquote {
        margin: 1.5rem 0;
        padding: 0.9rem 1rem;
        border-left: 4px solid var(--link);
        background: #eff6ff;
        color: var(--text);
        border-radius: 8px;
      }

      code {
        font-family:
          ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
        font-size: 0.95em;
        background: #f1f5f9;
        padding: 0.15em 0.4em;
        border-radius: 6px;
      }

      pre {
        overflow-x: auto;
        background: #0f172a;
        color: #e2e8f0;
        padding: 1rem;
        border-radius: 12px;
      }

      pre code {
        background: transparent;
        padding: 0;
        color: inherit;
      }

      table {
        width: 100%;
        border-collapse: collapse;
        margin: 1.5rem 0;
        font-size: 0.97rem;
        overflow: hidden;
        border: 1px solid var(--border);
        border-radius: 14px;
      }

      th,
      td {
        text-align: left;
        padding: 0.85rem 0.9rem;
        border-bottom: 1px solid var(--border);
        vertical-align: top;
      }

      th {
        background: #f8fafc;
        color: var(--text);
        font-weight: 600;
      }

      tr:last-child td {
        border-bottom: 0;
      }

      img {
        max-width: 100%;
        height: auto;
        border-radius: 12px;
      }

      @media (max-width: 640px) {
        main {
          margin: 20px 12px 32px;
          padding: 22px 18px 36px;
          border-radius: 16px;
        }

        h1 {
          font-size: 1.9rem;
        }

        th,
        td {
          padding: 0.7rem;
        }
      }
      /* HEADER */

      .site-header {
        padding: 0 20px;
        position: sticky;
        top: 0;
        background: rgba(255, 255, 255, 0.85);
        backdrop-filter: blur(8px);
        border-bottom: 1px solid var(--border);
        z-index: 10;
      }

      .nav {
        max-width: 820px; /* match main */
        margin: 0 auto;
        padding: 14px 0; /* remove side padding */
        display: flex;
        align-items: center;
        justify-content: space-between;
      }

      .logo a {
        font-weight: 700;
        font-size: 1.1rem; /* slightly larger */
        letter-spacing: -0.01em; /* tighter, more premium */
        color: var(--text);
        text-decoration: none;
      }

      .logo a:hover {
        opacity: 0.8;
      }

      nav a {
        display: inline-block;
        margin-left: 20px;
        font-size: 0.95rem;
        color: var(--muted);
        text-decoration: none;
        padding-bottom: 12px;
        border-bottom: 2px solid transparent;
        transition:
          color 0.2s ease,
          border-color 0.2s ease;
      }

      nav a.active {
        color: var(--text);
        font-weight: 700;
        border-bottom-color: var(--link);
      }

      nav a:hover {
        color: var(--text);
      }
    </style>
  </head>
  <body>
    <header class="site-header">
      <div class="nav">
        <div class="logo">
          <a href="/">Sole Trader Basics</a>
        </div>

        <nav>
          <a
            href="/guides/getting-started/"
            class={path.startsWith("/guides/getting-started") ? "active" : ""}
          >
            Start
          </a>

          <a
            href="/guides/banking/"
            class={path.startsWith("/guides/banking") ? "active" : ""}
          >
            Banking
          </a>

          <a
            href="/guides/accounting-software/"
            class={path.startsWith("/guides/accounting-software")
              ? "active"
              : ""}
          >
            Accounting
          </a>

          <a
            href="/best/accounting-software-sole-trader"
            class={path.startsWith("/best") ? "active" : ""}
          >
            Best Tools
          </a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>
  </body>
</html>
